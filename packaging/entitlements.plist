<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- THE fix: a hardened-runtime app cannot use the microphone without this.
         Without it AVCaptureDevice.requestAccess returns granted=False with no
         dialog, and the mic records silence (peak=0.0). -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Standard relaxations a notarized PyInstaller/Python app needs under the
         hardened runtime: Python's dynamic code + bundled native libs (ctranslate2,
         onnxruntime, faster-whisper) must be allowed to load and run. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
